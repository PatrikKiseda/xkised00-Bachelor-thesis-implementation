# ----------------------------------------
# App config (defaults for local development)
# ----------------------------------------
APP_NAME=rag-thesis-app
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

# ----------------------------------------
# Qdrant config
# Required: QDRANT_URL, QDRANT_COLLECTION
# ----------------------------------------
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=documents
QDRANT_TIMEOUT_SECONDS=3.0
QDRANT_API_KEY=

# ----------------------------------------
# Local storage config
# ----------------------------------------
SQLITE_PATH=./data/app.db
STORAGE_DIR=./data/uploads
# Chunking defaults can be tuned for experiments without code changes.
CHUNK_SIZE_CHARS=1000
CHUNK_OVERLAP_CHARS=150
# In this stage we explicidly set the vector size for Qdrant to the embedding model(text-embedding-3-small) 
# output size (https://developers.openai.com/api/docs/guides/embeddings/). For more flexibility this 
# will be later updated to be dynamic based on the embedding model used.
QDRANT_VECTOR_SIZE=1536

# ----------------------------------------
# Model config
# Required: LITELLM_MODEL, EMBEDDING_PROVIDER, EMBEDDING_MODEL
# OPENAI_API_KEY is required when EMBEDDING_PROVIDER=openai, with a check in settings.py    
# ----------------------------------------
LITELLM_MODEL=openai/gpt-5.4-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# Switch for local/test embeddings (no external provider API calls). 
EMBEDDING_API_ENABLED=true
OPENAI_API_KEY=replace-with-real-key-when-using-openai

# ----------------------------------------
# Deployment web config
# Used by docker-compose.deploy.yml
# ----------------------------------------
# Cloudflare Tunnel token from the tunnel connector setup command.
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

# Local check port. Keep it on 127.0.0.1 unless you intentionally need LAN access.
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=8090

# Generate BASIC_AUTH_HASH with:
# docker run --rm caddy:2.8-alpine caddy hash-password --plaintext 'your-password'
BASIC_AUTH_USER=replace-me
BASIC_AUTH_HASH=replace-with-caddy-hash
